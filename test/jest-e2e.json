{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "e2e/.*\\.e2e-spec\\.ts$",
  "testTimeout": 30000,
  "forceExit": true,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.+)\\.js$": "$1"
  }
}
